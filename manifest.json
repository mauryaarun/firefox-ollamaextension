{
  "manifest_version": 3,
  "name": "Local AI Multimodal Sidebar",
  "version": "2.1.0",
  "description": "Ollama assistant supporting vision models, context collection, and custom configurations.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:11434/*",
    "http://127.0.0.1:11434/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "Toggle AI Sidebar",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "sidebar_action": {
    "default_title": "AI Suite",
    "default_panel": "sidebar.html",
    "default_icon": "icons/icon48.png"
  },
  "commands": {
    "_execute_sidebar_action": {
      "suggested_key": { "default": "Alt+Shift+A" }
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ollama-multimodal-sidebar@local",
      "strict_min_version": "109.0"
    }
  }
}
