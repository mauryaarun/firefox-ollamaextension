{
  "manifest_version": 3,
  "name": "Local AI Workspace",
  "version": "1.0.0",
  "description": "Local AI assistant with RAG, multi-modal support, and advanced features",
  "icons": {
    "48": "icon.png",
    "96": "icon.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "contextMenus",
    "activeTab",
    "clipboardWrite"
  ],

   "host_permissions": [
    "http://localhost:*/",
    "http://127.0.0.1:*/",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background.js"]
  },
  "sidebar_action": {
    "default_title": "Local AI",
    "default_panel": "sidebar.html",
    "default_icon": "icon.png"
  },
  "action": {
    "default_title": "Open Local AI Sidebar",
    "default_icon": "icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "preview.html",
        "rag-worker.js",
        "lib/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
